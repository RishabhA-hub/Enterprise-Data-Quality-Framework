{
  "title": "Data Quality Framework — Executive Overview",
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "1m",
  "tags": ["dq","governance","executive"],
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "domain",
        "label": "Data domain",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "dq_reporting" },
        "query": "SELECT DISTINCT data_domain FROM dq_meta.dq_rules ORDER BY 1",
        "includeAll": true, "multi": true
      },
      {
        "name": "env",
        "type": "custom",
        "query": "dev,stg,prd",
        "current": { "text": "prd", "value": "prd" }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Overall Pass Rate (7d)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "dq_reporting" },
        "rawSql": "SELECT overall_pass_rate FROM reporting.v_executive_scorecard"
      }],
      "fieldConfig": { "defaults": {
        "unit": "percentunit", "min": 0, "max": 1,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red",    "value": 0    },
          { "color": "orange", "value": 0.85 },
          { "color": "green",  "value": 0.95 }
        ]}
      }}
    },
    {
      "type": "stat",
      "title": "Open CRITICAL Alerts",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "dq_reporting" },
        "rawSql": "SELECT count(*) FROM reporting.v_active_alerts WHERE severity='CRITICAL'"
      }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [
        { "color": "green", "value": 0 }, { "color": "red", "value": 1 }
      ]}}}
    },
    {
      "type": "timeseries",
      "title": "Pipeline duration (P50 / P95 / P99)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 7 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(dq_rule_duration_ms_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(dq_rule_duration_ms_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(dq_rule_duration_ms_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "table",
      "title": "Top failing rules (24h)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 11 },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "dq_reporting" },
        "rawSql": "SELECT rule_name, severity, target_table, failed_rows, executed_at FROM reporting.v_rule_results_detail WHERE status='FAIL' AND executed_at > now() - interval '24 hours' ORDER BY failed_rows DESC LIMIT 25"
      }]
    },
    {
      "type": "heatmap",
      "title": "Table health (30d)",
      "gridPos": { "x": 0, "y": 11, "w": 24, "h": 8 },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "dq_reporting" },
        "rawSql": "SELECT day, table_full_name, pass_rate FROM reporting.v_table_health"
      }]
    }
  ]
}
